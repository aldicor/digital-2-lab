#include "funcionesSensor.h"
#include <stdio.h>
#include "xil_printf.h"
#include "xparameters.h"
#include "xuartps.h"
#include "sleep.h"

int main() {
    XUartPs uart;
    XUartPs_Config *uart_config;

    // Inicializaciˇn UART con verificaciˇn
    uart_config = XUartPs_LookupConfig(XPAR_XUARTPS_1_DEVICE_ID);
    if (uart_config == NULL) {
        xil_printf("ERROR: No se encontro configuracion UART\r\n");
        return XST_FAILURE;
    }

    if (XUartPs_CfgInitialize(&uart, uart_config, uart_config->BaseAddress) != XST_SUCCESS) {
        xil_printf("ERROR: Fallo al inicializar UART\r\n");
        return XST_FAILURE;
    }

    if (XUartPs_SetBaudRate(&uart, 57600) != XST_SUCCESS) {
        xil_printf("ERROR: Fallo al configurar baudrate\r\n");
        return XST_FAILURE;
    }

    Adafruit_Fingerprint finger;
    Adafruit_Fingerprint_init(&finger, &uart);
    finger.timeout = 3000; // Timeout de 3 segundos

    xil_printf("Sistema de huella digital iniciado\r\n");

    while(1) {
        xil_printf("Esperando dedo...\r\n");

        uint8_t result = getImage(&finger);
        xil_printf("getImage retorno: 0x%02X\r\n", result);

        if (result == FINGERPRINT_NOFINGER) {
            usleep(500000);
            continue;
        }
        else if (result == FINGERPRINT_OK) {
            xil_printf("Imagen capturada\r\n");

            result = genChar(&finger, 1);
            xil_printf("genChar retorno: 0x%02X\r\n", result);

            if (result == FINGERPRINT_OK) {
                xil_printf("Buscando huella...\r\n");
                result = fingerFastSearch(&finger, 1, 0, 300);
                xil_printf("fingerFastSearch retorno: 0x%02X\r\n", result);

                if (result == FINGERPRINT_OK) {
                    xil_printf("Huella encontrada! ID: %d, Confianza: %d\r\n",
                              finger.fingerID, finger.confidence);
                    sleep(2); // Pausa despuÚs de encontrar huella
                }
                else if (result == FINGERPRINT_NOTFOUND) {
                    xil_printf("Huella no registrada\r\n");
                }
                else {
                    xil_printf("Error en busqueda: 0x%02X\r\n", result);
                }
            }
            else {
                xil_printf("Error en genChar: 0x%02X\r\n", result);
            }
        }
        else {
            xil_printf("Error en getImage: 0x%02X\r\n", result);
        }

        usleep(500000); // Espera entre intentos
    }

    return 0;
}
