#include "xparameters.h"
#include "xuartps.h"
#include "xil_printf.h"

#define XPAR_XUARTPS_1_DEVICE_ID XPAR_PS7_UART_1_DEVICE_ID

int main() {
    XUartPs uart;
    XUartPs_Config *cfg;

    // Inicializa UART1
    cfg = XUartPs_LookupConfig(UART_DEVICE_ID);
    XUartPs_CfgInitialize(&uart, cfg, cfg->BaseAddress);

    // Opcional: configura la velocidad (debes igualarla en PuTTY)
    XUartPs_SetBaudRate(&uart, 115200);  // Usa 115200 si puedes

    // Imprime por consola (esto ir· a PuTTY si todo est· bien)
    xil_printf("Hola desde UART1 (USB)\n");

    while (1) {
        xil_printf("Mensaje desde Zybo...\n");
        for (volatile int i = 0; i < 100000000; i++); // delay b·sico
    }

    return 0;
}
