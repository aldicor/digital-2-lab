#ifndef AS608_H
#define AS608_H

#include <stdint.h>
#include <stdbool.h>

// Status codes
#define AS608_OK           0x00
#define AS608_NOFINGER     0x02
#define AS608_IMAGEFAIL    0x03
#define AS608_FEATUREFAIL  0x06
#define AS608_NOMATCH      0x09
#define AS608_TIMEOUT      0xFE
#define AS608_ERROR        0xFF

// Sensor interface
bool AS608_Init(uint32_t password);
uint8_t AS608_CaptureImage(void);
uint8_t AS608_GenerateTemplate(uint8_t bufferID);
uint8_t AS608_SearchFinger(uint16_t *foundID, uint16_t *score);

// Sensor UART communication (UART0)
void AS608_UART_Init();
void AS608_UART_Send(const uint8_t *data, uint16_t len);
int  AS608_UART_Receive(uint8_t *data, uint16_t maxlen, int timeout_ms);

#endif
