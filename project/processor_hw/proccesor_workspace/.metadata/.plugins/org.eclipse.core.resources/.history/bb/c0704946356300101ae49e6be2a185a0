#include "as608.h"
#include "xil_printf.h"
#include "sleep.h"

int main() {
    // Init both UARTs
    PC_UART_Init();
    AS608_UART_Init();

    PC_Print("🟢 Starting AS608 mock test on Zynq-7000 (Zybo Z7)\r\n");

    // Mock sensor init
    if (!AS608_Init(0x00000000)) {
        PC_Print("❌ Sensor init failed (mock)\r\n");
        return -1;
    }

    PC_Print("✅ Sensor initialized (mock)\r\n");

    while (1) {
        PC_Print("\r\n👉 Place your finger (simulated)...\r\n");

        uint8_t res = AS608_CaptureImage();
        if (res == AS608_NOFINGER) {
            PC_Print("⚠️  No finger detected\r\n");
            sleep(1);
            continue;
        }

        PC_Print("📸 Image captured!\r\n");

        res = AS608_GenerateTemplate(1);
        if (res != AS608_OK) {
            PC_Print("❌ Failed to generate template\r\n");
            continue;
        }

        PC_Print("🧠 Template generated\r\n");

        uint16_t matchID, matchScore;
        res = AS608_SearchFinger(&matchID, &matchScore);
        if (res == AS608_OK) {
            char buf[64];
            sprintf(buf, "✅ Match found! ID: %d, Score: %d\r\n", matchID, matchScore);
            PC_Print(buf);
        } else {
            PC_Print("❌ No match found\r\n");
        }

        sleep(2);
    }

    return 0;
}
