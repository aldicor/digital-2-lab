#include "funcionesSensor.h"
#include "xuartps.h"
#include "xparameters.h"
#include "xil_printf.h"
#include "sleep.h"

int main() {
    XUartPs uart;
    XUartPs_Config *cfg;

    // --- Inicializar UART0 para el sensor y xil_printf ---
    cfg = XUartPs_LookupConfig(XPAR_XUARTPS_0_DEVICE_ID);
    XUartPs_CfgInitialize(&uart, cfg, cfg->BaseAddress);
    XUartPs_SetBaudRate(&uart, 57600);

    // Inicializar el sensor
    Adafruit_Fingerprint finger;
    Adafruit_Fingerprint_init(&finger, &uart);

    xil_printf("Sistema listo. Espera huella...\r\n");

    while (1) {
        uint8_t res = getImage(&finger);
        if (res == FINGERPRINT_NOFINGER) {
            xil_printf("Coloque el dedo...\r\n");
        } else if (res == FINGERPRINT_OK) {
            xil_printf("Imagen OK, generando características...\r\n");
            res = genChar(&finger, 1);
            if (res == FINGERPRINT_OK) {
                xil_printf("Char OK, buscando huella...\r\n");
                res = fingerFastSearch(&finger, 1, 0, 300);
                if (res == FINGERPRINT_OK) {
                    xil_printf("ˇHuella reconocida! ID=%d Conf=%d\r\n",
                               finger.fingerID, finger.confidence);
                } else {
                    xil_printf("No encontrada (0x%02X)\r\n", res);
                }
            } else {
                xil_printf("Error genChar: 0x%02X\r\n", res);
            }
        } else {
            xil_printf("Error getImage: 0x%02X\r\n", res);
        }
        usleep(500000);
    }

    return 0;
}

