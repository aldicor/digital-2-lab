#include "as608.h"
#include "xuartps.h"
#include "xparameters.h"
#include "xtime_l.h"

#define SENSOR_UART_DEVICE_ID XPAR_XUARTPS_0_DEVICE_ID

static XUartPs UartSensor;

void AS608_UART_Init() {
    XUartPs_Config *Config = XUartPs_LookupConfig(SENSOR_UART_DEVICE_ID);
    XUartPs_CfgInitialize(&UartSensor, Config, Config->BaseAddress);
    XUartPs_SetBaudRate(&UartSensor, 57600);  // AS608 default baud
}

void AS608_UART_Send(const uint8_t *data, uint16_t len) {
    XUartPs_Send(&UartSensor, data, len);
    while (XUartPs_IsSending(&UartSensor));
}

int AS608_UART_Receive(uint8_t *data, uint16_t maxlen, int timeout_ms) {
    uint16_t count = 0;
    XTime start, now;
    XTime_GetTime(&start);

    while (count < maxlen) {
        int read = XUartPs_Recv(&UartSensor, &data[count], 1);
        if (read > 0) count++;

        XTime_GetTime(&now);
        if ((now - start) / (XPAR_CPU_CORTEXA9_0_CPU_CLK_FREQ_HZ / 1000) > timeout_ms) break;
    }

    return count;
}

static void buildPacket(uint8_t *packet, uint8_t cmd, uint8_t *data, uint16_t len) {
    uint32_t addr = 0xFFFFFFFF;
    packet[0] = 0xEF;
    packet[1] = 0x01;
    packet[2] = (addr >> 24) & 0xFF;
    packet[3] = (addr >> 16) & 0xFF;
    packet[4] = (addr >> 8) & 0xFF;
    packet[5] = addr & 0xFF;
    packet[6] = 0x01;
    packet[7] = ((len + 2) >> 8) & 0xFF;
    packet[8] = (len + 2) & 0xFF;
    packet[9] = cmd;

    for (int i = 0; i < len; i++)
        packet[10 + i] = data[i];

    uint16_t sum = 0;
    for (int i = 6; i < 10 + len; i++)
        sum += packet[i];

    packet[10 + len] = (sum >> 8) & 0xFF;
    packet[11 + len] = sum & 0xFF;
}

static int sendCommand(uint8_t cmd, uint8_t *data, uint16_t len, uint8_t *resp, int respLen, int timeout) {
    uint8_t packet[32];
    buildPacket(packet, cmd, data, len);
    AS608_UART_Send(packet, 12 + len);
    return AS608_UART_Receive(resp, respLen, timeout);
}

bool AS608_Init(uint32_t password) {
    uint8_t pwd[4] = {
        (password >> 24) & 0xFF,
        (password >> 16) & 0xFF,
        (password >> 8) & 0xFF,
        password & 0xFF
    };
    uint8_t response[16];
    int len = sendCommand(0x13, pwd, 4, response, sizeof(response), 1000);
    return (len >= 12 && response[9] == AS608_OK);
}

uint8_t AS608_CaptureImage(void) {
    uint8_t response[16];
    int len = sendCommand(0x01, NULL, 0, response, sizeof(response), 1000);
    return (len >= 12) ? response[9] : AS608_TIMEOUT;
}

uint8_t AS608_GenerateTemplate(uint8_t bufferID) {
    uint8_t response[16];
    int len = sendCommand(0x02, &bufferID, 1, response, sizeof(response), 1000);
    return (len >= 12) ? response[9] : AS608_TIMEOUT;
}

uint8_t AS608_SearchFinger(uint16_t *foundID, uint16_t *score) {
    uint8_t args[6] = {0x01, 0x00, 0x00, 0x00, 0xA3, 0x00};
    uint8_t response[20];
    int len = sendCommand(0x04, args, 6, response, sizeof(response), 1000);

    if (len >= 16 && response[9] == AS608_OK) {
        *foundID = (response[10] << 8) | response[11];
        *score = (response[12] << 8) | response[13];
        return AS608_OK;
    }
    return (len >= 12) ? response[9] : AS608_TIMEOUT;
}
