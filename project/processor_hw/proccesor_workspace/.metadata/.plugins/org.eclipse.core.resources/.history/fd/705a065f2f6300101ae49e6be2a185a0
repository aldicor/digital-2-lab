#include "funcionesSensor.h"
#include "xparameters.h"
#include "xuartps.h"
#include "sleep.h"
#include <stdio.h>
#include <string.h>

#define UART_PC_ID XPAR_XUARTPS_1_DEVICE_ID   // UART1 - va al PC (Putty)
#define UART_SENSOR_ID XPAR_XUARTPS_0_DEVICE_ID // UART0 - va al sensor AS608

int main() {
    XUartPs uart_pc, uart_sensor;
    XUartPs_Config *cfg_pc, *cfg_sensor;
    char buf[64];
    int len;

    // Inicializar UART1 (para consola PC)
    cfg_pc = XUartPs_LookupConfig(UART_PC_ID);
    XUartPs_CfgInitialize(&uart_pc, cfg_pc, cfg_pc->BaseAddress);
    XUartPs_SetBaudRate(&uart_pc, 115200); // Consola en Putty debe estar igual

    // Inicializar UART0 (para sensor)
    cfg_sensor = XUartPs_LookupConfig(UART_SENSOR_ID);
    XUartPs_CfgInitialize(&uart_sensor, cfg_sensor, cfg_sensor->BaseAddress);
    XUartPs_SetBaudRate(&uart_sensor, 57600); // O prueba con 115200 si no responde

    // Inicializar objeto sensor
    Adafruit_Fingerprint finger;
    Adafruit_Fingerprint_init(&finger, &uart_sensor);

    XUartPs_Send(&uart_pc, (uint8_t*)"Sistema listo. Espera huella...\r\n", 34);

    while (1) {
        uint8_t res = getImage(&finger);

        len = snprintf(buf, sizeof(buf), "getImage() => 0x%02X\r\n", res);
        XUartPs_Send(&uart_pc, (uint8_t*)buf, len);

        if (res == FINGERPRINT_NOFINGER) {
            XUartPs_Send(&uart_pc, (uint8_t*)"Coloque el dedo...\r\n", 21);
        } else if (res == FINGERPRINT_OK) {
            XUartPs_Send(&uart_pc, (uint8_t*)"Imagen OK\r\n", 11);
        } else if (res == FINGERPRINT_PACKETRECIEVEERR) {
            XUartPs_Send(&uart_pc, (uint8_t*)"Error: PACKET ERROR\r\n", 22);
        } else if (res == FINGERPRINT_IMAGEFAIL) {
            XUartPs_Send(&uart_pc, (uint8_t*)"Error: IMAGE FAIL\r\n", 20);
        } else if (res == FINGERPRINT_ERROR_TIMEOUT) {
            XUartPs_Send(&uart_pc, (uint8_t*)"Error: TIMEOUT\r\n", 17);
        } else if (res == FINGERPRINT_ERROR_COMMUNICATION) {
            XUartPs_Send(&uart_pc, (uint8_t*)"Error: COMUNICACION\r\n", 23);
        } else {
            len = snprintf(buf, sizeof(buf), "Error desconocido: 0x%02X\r\n", res);
            XUartPs_Send(&uart_pc, (uint8_t*)buf, len);
        }

        usleep(500000); // medio segundo
    }

    return 0;
}

