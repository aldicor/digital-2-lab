#include "funcionesSensor.h"
#include "xparameters.h"
#include "xuartps.h"
#include "xil_printf.h"
#include "sleep.h"

int main() {
    XUartPs uart;
    XUartPs_Config *uart_config;

    // Inicializar UART
    uart_config = XUartPs_LookupConfig(XPAR_XUARTPS_0_DEVICE_ID);
    XUartPs_CfgInitialize(&uart, uart_config, uart_config->BaseAddress);
    XUartPs_SetBaudRate(&uart, 57600);

    // Inicializar sensor de huellas
    Adafruit_Fingerprint finger;
    Adafruit_Fingerprint_init(&finger, &uart);

    // Esperar hasta que se detecte una huella válida registrada
    while (1) {
        if (getImage(&finger) == FINGERPRINT_OK) {
            if (genChar(&finger, 1) == FINGERPRINT_OK) {
                if (fingerFastSearch(&finger, 1, 0, 300) == FINGERPRINT_OK) {
                    xil_printf("LEÍ\n");
                    break;  // salir del loop después de leer exitosamente
                }
            }
        }
        usleep(500000); // Espera medio segundo antes de intentar de nuevo
    }

    return 0;
}
